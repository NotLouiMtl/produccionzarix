---
import Navbar from '../components/Navbar.jsx';
import Footer from '../components/Footer.jsx';
import PrivacyModal from '../components/PrivacyModal.jsx';
import TermsModal from '../components/TermsModal.jsx';
import WhatsappFloat from '../components/WhatsappFloat.jsx';

interface Props {
  title: string;
  description?: string;
  ogImage?: string;
}

const { title, description = "Zarix — Engenharia de Infraestruturas IT & Cibersegurança em Aveiro", ogImage } = Astro.props;
const canonicalURL = Astro.url.href;
---

<!DOCTYPE html>
<html lang="pt" class="scroll-smooth bg-[#07090e]">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" type="image/png" sizes="96x96" href="/favicon-96x96.png" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    {ogImage && <meta property="og:image" content={ogImage} />}
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500&family=Plus+Jakarta+Sans:wght@300;400;700;800&display=swap" rel="stylesheet">
  </head>
  <body class="text-white font-sans antialiased selection:bg-blue-500/20">
    
    <Navbar client:load />

    <slot />

    <Footer client:load />

    <PrivacyModal client:load />
    <TermsModal client:load />

    <WhatsappFloat client:idle />

    <script>
      import Lenis from 'lenis';

      const lenis = new Lenis({
        duration: 1.2,
        easing: (t) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
        smoothWheel: true
      });

      function raf(time: number) {
        lenis.raf(time);
        requestAnimationFrame(raf);
      }
      requestAnimationFrame(raf);
    </script>
  </body>
</html>

<style is:global>
  @tailwind base;
  @tailwind components;
  @tailwind utilities;
  :root { --font-sans: 'Plus Jakarta Sans', sans-serif; --font-mono: 'JetBrains Mono', sans-serif; }
  body { font-family: var(--font-sans); }
</style>
