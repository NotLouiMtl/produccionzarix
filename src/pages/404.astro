---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Página não encontrada — Zarix">
  <main class="min-h-screen flex flex-col items-center justify-center px-6 text-center">
    <span class="font-mono text-[10px] text-blue-500 uppercase tracking-widest block mb-4">// Error 404</span>
    <h1 class="text-6xl md:text-8xl font-black text-white tracking-tighter uppercase">Página não encontrada</h1>
    <p class="text-slate-400 font-light text-lg mt-4 max-w-md">O caminho que procura não existe na nossa infraestrutura.</p>
    <a href="/" class="mt-10 font-mono text-xs font-medium tracking-wider uppercase border border-blue-500/30 bg-blue-600/10 text-blue-400 px-8 py-4 rounded-sm hover:bg-blue-600 hover:text-white transition-all duration-300">
      Voltar ao início →
    </a>
  </main>
</Layout>
