<script>
  document.addEventListener('DOMContentLoaded', () => {
    const form = document.getElementById('zarix-mailto-form');
    if (!form) return;

    form.addEventListener('submit', (e) => {
      e.preventDefault();

      const name = document.getElementById('name').value;
      const email = document.getElementById('email').value;
      const phone = document.getElementById('phone').value || 'Não fornecido';
      const subject = document.getElementById('subject').value;
      const message = document.getElementById('message').value;

      const mailtoSubject = encodeURIComponent(`[ZARIX DIAGNÓSTICO] - ${subject} (${name})`);
      const mailtoBody = encodeURIComponent(
        `==================================================\n` +
        `       SOLICITAÇÃO DE DIAGNÓSTICO TÉCNICO         \n` +
        `==================================================\n\n` +
        `// 01. DADOS DO CLIENTE\n` +
        `--------------------------------------------------\n` +
        `Nome: ${name}\n` +
        `E-mail: ${email}\n` +
        `Contacto: ${phone}\n\n` +
        `// 02. MÓDULO ALVO REQUISITADO\n` +
        `--------------------------------------------------\n` +
        `Serviço: ${subject}\n\n` +
        `// 03. ESPECIFICAÇÕES DO PROBLEMA (MENSAGEM)\n` +
        `--------------------------------------------------\n` +
        `${message}\n\n` +
        `==================================================\n` +
        `Fim do log de recepção. Aguardando execução interna.\n` +
        `==================================================`
      );

      window.location.href = `mailto:geral@zarix.site?subject=${mailtoSubject}&body=${mailtoBody}`;
    });
  });
</script>

<style>
  .stat-value {
    opacity: 0;
    transform: translateY(12px);
    transition: opacity 0.5s ease, transform 0.5s ease;
  }
  .stat-value.visible {
    opacity: 1;
    transform: translateY(0);
  }
  .modal-overlay {
    position: fixed;
    inset: 0;
    z-index: 999;
    background: rgba(0,0,0,0.75);
    backdrop-filter: blur(8px);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 1rem;
  }
  .modal-overlay.hidden {
    display: none;
  }
  .modal-content {
    background: #0F1626;
    border: 1px solid #1e293b;
    border-radius: 1rem;
    padding: 2rem;
    max-width: 480px;
    width: 100%;
    position: relative;
    box-shadow: 0 25px 60px rgba(0,0,0,0.5);
  }
  .modal-close {
    position: absolute;
    top: 1rem;
    right: 1rem;
    width: 2rem;
    height: 2rem;
    border-radius: 9999px;
    border: 1px solid #1e293b;
    background: #0B0F19;
    color: #64748b;
    font-size: 1.25rem;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    transition: all 0.2s;
  }
  .modal-close:hover {
    border-color: #3b82f6;
    color: white;
  }
</style>

<script>
  document.addEventListener('DOMContentLoaded', () => {
    const section = document.getElementById('stats-section');
    if (section) {
      const els = section.querySelectorAll('.stat-value');
      const observer = new IntersectionObserver((entries) => {
        entries.forEach(entry => {
          if (!entry.isIntersecting) return;
          observer.disconnect();
          els.forEach((el, i) => {
            setTimeout(() => {
              el.classList.add('visible');
              const target = el.dataset.target;
              if (target.includes('ms') && !isNaN(parseFloat(target))) {
                const num = parseFloat(target);
                animateNumber(el, 0, num, 1200, v => v.toFixed(2) + 'ms');
              } else if (target.includes('%') && !isNaN(parseInt(target))) {
                const num = parseInt(target);
                animateNumber(el, 0, num, 1200, v => v + '%');
              } else {
                typeText(el, target, 600);
              }
            }, i * 200);
          });
        });
      }, { threshold: 0.5 });
      observer.observe(section);
    }

    function animateNumber(el, start, end, duration, format) {
      const startTime = performance.now();
      function step(now) {
        const elapsed = now - startTime;
        const progress = Math.min(elapsed / duration, 1);
        const eased = 1 - Math.pow(1 - progress, 3);
        const current = start + (end - start) * eased;
        el.textContent = format(Math.round(current * 100) / 100);
        if (progress < 1) requestAnimationFrame(step);
      }
      requestAnimationFrame(step);
    }

    function typeText(el, text, duration) {
      el.textContent = '';
      let i = 0;
      const chars = text.split('');
      const interval = duration / chars.length;
      const timer = setInterval(() => {
        el.textContent += chars[i++];
        if (i >= chars.length) clearInterval(timer);
      }, interval);
    }

    document.querySelectorAll('.modal-trigger').forEach(btn => {
      btn.addEventListener('click', () => {
        const modalId = btn.dataset.modal;
        const modal = document.getElementById(modalId);
        if (modal) modal.classList.remove('hidden');
      });
    });
    document.querySelectorAll('.modal-close').forEach(btn => {
      btn.addEventListener('click', () => {
        btn.closest('.modal-overlay').classList.add('hidden');
      });
    });
    document.querySelectorAll('.modal-overlay').forEach(overlay => {
      overlay.addEventListener('click', (e) => {
        if (e.target === overlay) overlay.classList.add('hidden');
      });
    });
  });
</script>
