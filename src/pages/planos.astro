---
import Layout from '../layouts/Layout.astro';
import OrcamentoZarix from '../components/OrcamentoZarix.jsx';
---

<Layout title="Orçamento Personalizado — Zarix">
  <main class="bg-[#0B0F19] text-slate-100 min-h-screen pt-28 pb-24 px-4 sm:px-6 lg:px-8 relative overflow-hidden selection:bg-blue-500/30 selection:text-blue-200 antialiased">

    <div class="absolute inset-0 z-0 bg-[linear-gradient(to_right,#1e293b12_1px,transparent_1px),linear-gradient(to_bottom,#1e293b12_1px,transparent_1px)] bg-[size:4rem_4rem] [mask-image:radial-gradient(ellipse_60%_50%_at_50%_30%,#000_60%,transparent_100%)] pointer-events-none"></div>

    <div class="absolute top-[10%] right-[10%] w-[35rem] h-[35rem] bg-gradient-to-tr from-blue-600/10 to-indigo-600/5 rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute bottom-[20%] left-[-5%] w-[25rem] h-[25rem] bg-cyan-500/5 rounded-full blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto relative z-10 space-y-16">

      <section class="text-center pt-12 md:pt-20 pb-8 md:pb-16 space-y-6 max-w-3xl mx-auto">
        <div class="inline-flex items-center space-x-2 text-xs font-mono text-blue-400 bg-blue-500/5 border border-blue-500/20 px-3 py-1.5 rounded-full uppercase tracking-wider">
          <span class="w-2 h-2 rounded-full bg-emerald-400 animate-ping"></span>
          <span>System_Status: Orçamento_Online // v2.0</span>
        </div>
        <h1 class="text-4xl sm:text-6xl font-black font-sans tracking-tight text-white leading-[1.05]">
          Monta o teu<br/>
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-blue-400 via-cyan-400 to-indigo-400">pack tecnológico.</span>
        </h1>
      </section>

      <OrcamentoZarix client:load />

    </div>
  </main>
</Layout>
