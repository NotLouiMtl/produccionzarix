---
import Layout from '../layouts/Layout.astro';

const posts = [
  {
    title: "Como proteger o seu negócio local contra Ransomware em 2026",
    date: "Maio 14, 2026",
    category: "Cibersegurança",
    excerpt: "Estratégias críticas de isolamento de rede e políticas de backup invioláveis para PMEs e pequenos comércios situados em Aveiro."
  },
  {
    title: "Otimização de Redes Wi-Fi para Restauração: Guia Completo",
    date: "Abril 28, 2026",
    category: "Infraestrutura",
    excerpt: "Por que segmentar a rede dos seus clientes através de VLANs dedicadas evita falhas catastróficas nos sistemas de faturação interna."
  }
];
---

<Layout title="Blog — Zarix" description="Artigos técnicos sobre cibersegurança, infraestrutura de redes, otimização web e automação para empresas em Portugal.">
  <main class="max-w-5xl mx-auto px-6 pt-44 pb-32">
    <div class="mb-24 space-y-4">
      <span class="font-mono text-xs text-blue-500 uppercase tracking-widest block">// Conhecimento Partilhado</span>
      <h1 class="text-4xl md:text-6xl font-black uppercase tracking-tighter text-white">Notas de Engenharia.</h1>
      <p class="text-slate-400 font-light text-base">Guias práticos e atualizações sobre segurança, redes e automatização para empresários.</p>
    </div>

    <div class="space-y-16">
      {posts.map((post) => (
        <article class="group cursor-pointer border-b border-slate-900 pb-12 block">
          <div class="flex items-center gap-4 text-slate-500 font-mono text-xs mb-4">
            <span>{post.date}</span>
            <span>•</span>
            <span class="text-blue-500">// {post.category}</span>
          </div>
          <h2 class="text-2xl md:text-4xl font-black text-slate-300 group-hover:text-white transition-colors tracking-tight leading-tight">
            {post.title}
          </h2>
          <p class="text-slate-400 font-light mt-4 text-base max-w-3xl leading-relaxed">{post.excerpt}</p>
          <span class="inline-block mt-6 font-mono text-xs text-blue-400 group-hover:text-blue-300">Ler artigo completo →</span>
        </article>
      ))}
    </div>
  </main>
</Layout>
